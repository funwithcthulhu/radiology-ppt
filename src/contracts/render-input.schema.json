{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://funwithcthulhu.github.io/radiology-ppt/render-input.schema.json",
  "title": "Radiology PowerPoint Render Input",
  "type": "object",
  "additionalProperties": true,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["request", "caseData"],
        "properties": {
          "request": { "$ref": "case-request.schema.json" },
          "caseData": {
            "type": "object",
            "required": ["caseTitle", "images"],
            "additionalProperties": true,
            "properties": {
              "caseTitle": { "type": "string", "minLength": 1 },
              "images": {
                "type": "array",
                "items": { "$ref": "image-candidate.schema.json" }
              }
            }
          }
        }
      }
    },
    "args": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "deckMode": {
          "type": "string",
          "enum": ["case-conference", "core-review"]
        },
        "coreReviewQuestionSource": {
          "type": "string",
          "enum": ["bundled", "library", "question-bank"]
        },
        "coreReviewQuestionBankPath": { "type": "string" },
        "theme": { "type": "string" },
        "title": { "type": "string" },
        "out": { "type": "string" },
        "includeTeachingPoints": { "type": "boolean" }
      }
    }
  }
}
