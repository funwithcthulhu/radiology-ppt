{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://funwithcthulhu.github.io/radiology-ppt/prepare-input.schema.json",
  "title": "Radiology PowerPoint Prepare Input",
  "anyOf": [
    { "$ref": "#/$defs/entries" },
    {
      "type": "object",
      "additionalProperties": true,
      "required": ["entries"],
      "properties": {
        "entries": { "$ref": "#/$defs/entries" },
        "args": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "imagesPerCase": { "type": "integer", "minimum": 1 },
            "useClinicalHistory": { "type": "boolean" },
            "useOllamaAssist": { "type": "boolean" },
            "ollamaModel": { "type": "string" },
            "onlyNewRandomCases": { "type": "boolean" }
          }
        }
      }
    }
  ],
  "$defs": {
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "anyOf": [
          { "type": "string", "minLength": 1 },
          { "$ref": "case-request.schema.json" }
        ]
      }
    }
  }
}
