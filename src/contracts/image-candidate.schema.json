{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://funwithcthulhu.github.io/radiology-ppt/image-candidate.schema.json",
  "title": "Radiology PowerPoint Image Candidate",
  "type": "object",
  "additionalProperties": true,
  "required": ["url"],
  "properties": {
    "url": { "type": "string", "minLength": 1 },
    "localPath": { "type": "string" },
    "label": { "type": "string" },
    "studyId": { "type": ["string", "number", "null"] },
    "seriesId": { "type": ["string", "number", "null"] },
    "frameId": { "type": ["string", "number"] },
    "modality": { "type": ["string", "null"] },
    "plane": { "type": "string" },
    "sliceIndex": { "type": ["integer", "null"] },
    "relevantScore": { "type": "number" },
    "selectionExplanation": { "type": "string" },
    "audit": {
      "type": "object",
      "additionalProperties": true
    },
    "ollamaScore": { "type": ["number", "null"] },
    "isAnnotated": { "type": "boolean" },
    "isKeyImage": { "type": "boolean" },
    "isCurrent": { "type": "boolean" },
    "viewSignature": { "type": "string" },
    "focusPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" },
          "kind": { "type": "string" }
        }
      }
    }
  }
}
