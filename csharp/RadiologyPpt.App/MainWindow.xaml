<Window x:Class="RadiologyPpt.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radiopaedia Case PowerPoint Builder"
        Icon="Assets/app-icon.ico"
        Height="760"
        Width="1180"
        MinHeight="520"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#0B1F35">
            <DockPanel Margin="18,24,18,18">
                <StackPanel DockPanel.Dock="Top">
                    <Border Width="58" Height="48" CornerRadius="10" Background="#173A63" HorizontalAlignment="Left">
                        <TextBlock Text="RP" Foreground="#DBEAFE" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Radiopaedia Case&#x0a;PowerPoint Builder"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,12,0,22" />
                    <Button x:Name="CasesNavButton" Content="Cases" Click="CasesNav_Click" Margin="0,0,0,8" />
                    <Button x:Name="CoreReviewNavButton" Content="Core Review" Click="CoreBoardsNav_Click" Margin="0,0,0,8" />
                    <Button x:Name="LibraryNavButton" Content="Library" Click="LibraryNav_Click" Margin="0,0,0,8" />
                    <Button x:Name="ActivityNavButton" Content="Activity" Click="ActivityNav_Click" Margin="0,0,0,8" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="{Binding StatusText}" Foreground="#DBEAFE" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LastPowerPointText}" Foreground="#8FB3D8" FontSize="11"
                               TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Margin="28,24,28,16">
            <TabControl x:Name="MainTabs"
                        BorderThickness="0"
                        Background="Transparent"
                        Padding="0"
                        SelectionChanged="MainTabs_SelectionChanged">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Border Width="0" Height="0" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabItem Header="Cases">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="Cases" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" DockPanel.Dock="Left" Margin="0,0,12,0" />
                            <TextBlock Text="Build a case conference PowerPoint from selected diagnoses, random pulls, or exact Radiopaedia URLs."
                                       Style="{StaticResource PageSubtitle}" VerticalAlignment="Center" />
                        </DockPanel>

                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Case Conference" FontSize="18" FontWeight="SemiBold" Margin="0,0,14,0" />
                                    <TextBlock Text="Settings for PowerPoints generated from the case rows below."
                                               Foreground="{StaticResource MutedBrush}" FontSize="12"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </StackPanel>

                                <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                                    <StackPanel Width="280" Margin="0,0,12,8">
                                        <TextBlock Text="Title" FontWeight="SemiBold" />
                                        <TextBox x:Name="TitleBox" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Width="80" Margin="0,0,12,8">
                                        <TextBlock Text="Images" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImagesPerCaseBox" Text="3" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Width="220" Margin="0,0,12,8">
                                        <TextBlock Text="Theme" FontWeight="SemiBold" />
                                        <ComboBox x:Name="ThemeCombo" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Width="360" Margin="0,0,12,8">
                                        <TextBlock Text="Output .pptx" FontWeight="SemiBold" />
                                        <DockPanel LastChildFill="True" Margin="0,3,0,0">
                                            <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseOutput_Click" Padding="10,5" Margin="8,0,0,0" />
                                            <TextBox x:Name="OutputBox" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Width="300" Margin="0,0,12,8">
                                        <TextBlock Text="Preset" FontWeight="SemiBold" />
                                        <DockPanel LastChildFill="True" Margin="0,3,0,0">
                                            <Button DockPanel.Dock="Right" Content="Apply" Click="ApplyPreset_Click" Padding="10,5" Margin="8,0,0,0" />
                                            <ComboBox x:Name="PresetCombo" DisplayMemberPath="Name" SelectionChanged="PresetCombo_SelectionChanged" />
                                        </DockPanel>
                                        <TextBlock x:Name="PresetDescriptionText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Width="300" Margin="0,0,12,8">
                                        <TextBlock Text="Ollama image review" FontWeight="SemiBold" />
                                        <DockPanel LastChildFill="True" Margin="0,3,0,0">
                                            <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshOllama_Click" Padding="10,5" Margin="8,0,0,0" />
                                            <ComboBox x:Name="OllamaModelCombo" IsEditable="True" />
                                        </DockPanel>
                                        <CheckBox x:Name="OllamaCheck" Content="Enable optional review scoring" Margin="0,5,0,0" />
                                    </StackPanel>
                                    <UniformGrid Width="360" Columns="2" Margin="0,18,0,8">
                                        <CheckBox x:Name="AutoOpenCheck" Content="Open PowerPoint" IsChecked="True" Margin="0,0,10,4" />
                                        <CheckBox x:Name="ClinicalHistoryCheck" Content="Show age/sex" IsChecked="True" Margin="0,0,0,4" />
                                        <CheckBox x:Name="TeachingPointsCheck" Content="Teaching slides" Margin="0,0,10,0" />
                                        <CheckBox x:Name="OnlyNewRandomCheck"
                                                  Content="Only new cases"
                                                  IsChecked="True"
                                                  ToolTip="On by default. Random requests search Radiopaedia first and skip cases already used in previous random PowerPoints instead of backfilling with older cases." />
                                    </UniformGrid>
                                </WrapPanel>

                                <DockPanel Grid.Row="2">
                                    <WrapPanel DockPanel.Dock="Right">
                                        <Button x:Name="GenerateButton" Content="Generate PowerPoint" Style="{StaticResource PrimaryButton}" Click="Generate_Click" Padding="12,7" />
                                        <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click" IsEnabled="False" Padding="12,7" />
                                        <Button Content="Open Last" Click="OpenLastPowerPoint_Click" Padding="12,7" />
                                        <Button Content="Outputs" Click="OpenOutputs_Click" Padding="12,7" Margin="0" />
                                    </WrapPanel>
                                </DockPanel>
                            </Grid>
                        </Border>

                        <DockPanel Grid.Row="2" Margin="0,0,0,4">
                            <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="Add Row" Click="AddRow_Click" MinWidth="72" Padding="9,4" FontSize="12" />
                                <Button Content="Remove Selected" Click="RemoveSelectedRow_Click" MinWidth="110" Padding="9,4" FontSize="12" />
                                <Button Content="Load File" Click="LoadFile_Click" MinWidth="72" Padding="9,4" FontSize="12" Margin="0" />
                            </WrapPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="Case requests" FontSize="15" FontWeight="SemiBold" DockPanel.Dock="Left" Margin="0,0,12,0" />
                                <TextBlock Text="Add diagnoses, random pulls, or exact Radiopaedia URLs; use dropdowns instead of filter shorthand."
                                           Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
                            </DockPanel>
                        </DockPanel>

                        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="10" MinHeight="260" VerticalAlignment="Stretch">
                            <DataGrid x:Name="RequestsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridComboBoxColumn x:Name="ModeColumn" Header="Type" SelectedItemBinding="{Binding Mode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                    <DataGridTextColumn Header="Diagnosis / Random Text / URL" Binding="{Binding Query, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="Count" Binding="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                                    <DataGridComboBoxColumn x:Name="ModalityColumn" Header="Modality" SelectedItemBinding="{Binding Modality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                    <DataGridComboBoxColumn x:Name="AnatomyColumn" Header="Anatomy" SelectedItemBinding="{Binding Anatomy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                                    <DataGridComboBoxColumn x:Name="SubspecialtyColumn" Header="Area" SelectedItemBinding="{Binding Subspecialty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                                    <DataGridComboBoxColumn x:Name="AgeColumn" Header="Age" SelectedItemBinding="{Binding AgeGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                    <DataGridComboBoxColumn x:Name="TopicColumn" Header="Focus" SelectedItemBinding="{Binding TopicFocus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                    <DataGridComboBoxColumn x:Name="DifficultyColumn" Header="Difficulty" SelectedItemBinding="{Binding Difficulty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Core Review">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="Core Review" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" DockPanel.Dock="Left" Margin="0,0,12,0" />
                            <TextBlock Text="Generate CORE review lectures here; the Cases view is not used for this workflow."
                                       Style="{StaticResource PageSubtitle}" VerticalAlignment="Center" />
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,2" VerticalAlignment="Top">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="16,0,0,0"
                                                    VerticalAlignment="Top">
                                            <Button x:Name="GenerateCoreReviewButton" Content="Generate Core Review PowerPoint"
                                                    Style="{StaticResource PrimaryButton}" Click="GenerateCoreReviewPowerPoint_Click"
                                                    Padding="12,7" Height="36" />
                                            <Button x:Name="CoreReviewCancelButton" Content="Cancel" Click="Cancel_Click" IsEnabled="False"
                                                    Padding="12,7" Height="36" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Core Review PowerPoint" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="Plan the lecture, question mix, sources, and output from one place. NIS and physics count toward the total."
                                                       Foreground="{StaticResource MutedBrush}" FontSize="12"
                                                       TextWrapping="Wrap" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </DockPanel>

                                    <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                                        <StackPanel Width="300" Margin="0,0,12,8">
                                            <TextBlock Text="Title" FontWeight="SemiBold" />
                                            <TextBox x:Name="CoreReviewTitleBox" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="92" Margin="0,0,12,8">
                                            <TextBlock Text="Total items" FontWeight="SemiBold" />
                                            <TextBox x:Name="CoreReviewCaseCountBox" Text="50" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="220" Margin="0,0,12,8">
                                            <TextBlock Text="Domain" FontWeight="SemiBold" />
                                            <ComboBox x:Name="BoardDomainCombo" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="260" Margin="0,0,12,8">
                                            <TextBlock Text="Selection" FontWeight="SemiBold" />
                                            <ComboBox x:Name="CoreReviewCaseMixCombo" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="220" Margin="0,0,12,8">
                                            <TextBlock Text="Modality mix" FontWeight="SemiBold" />
                                            <ComboBox x:Name="CoreReviewModalityMixCombo" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="320" Margin="0,0,12,8">
                                            <TextBlock Text="Question source" FontWeight="SemiBold" />
                                            <ComboBox x:Name="CoreReviewQuestionSourceCombo" Margin="0,3,0,0"
                                                      SelectionChanged="CoreReviewQuestionSourceCombo_SelectionChanged" />
                                        </StackPanel>
                                        <StackPanel Width="220" Margin="0,0,12,8">
                                            <TextBlock Text="Theme" FontWeight="SemiBold" />
                                            <ComboBox x:Name="CoreReviewThemeCombo" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="360" Margin="0,0,12,8">
                                            <TextBlock Text="Output .pptx" FontWeight="SemiBold" />
                                            <DockPanel LastChildFill="True" Margin="0,3,0,0">
                                                <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseCoreReviewOutput_Click"
                                                        Padding="10,5" Margin="8,0,0,0" />
                                                <TextBox x:Name="CoreReviewOutputBox" />
                                            </DockPanel>
                                        </StackPanel>
                                        <StackPanel x:Name="CoreReviewQuestionBankGroup" Width="360" Margin="0,0,12,8">
                                            <TextBlock x:Name="CoreReviewQuestionBankLabel" Text="Question bank" FontWeight="SemiBold" />
                                            <DockPanel x:Name="CoreReviewQuestionBankPanel" LastChildFill="True" Margin="0,3,0,0">
                                                <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseCoreReviewQuestionBank_Click"
                                                        Padding="10,5" Margin="8,0,0,0" />
                                                <TextBox x:Name="CoreReviewQuestionBankBox" />
                                            </DockPanel>
                                        </StackPanel>
                                        <UniformGrid Width="360" Columns="2" Margin="0,18,0,8">
                                            <CheckBox x:Name="CoreReviewAutoOpenCheck" Content="Open PowerPoint" IsChecked="True" Margin="0,0,10,4" />
                                            <CheckBox x:Name="CoreReviewClinicalHistoryCheck" Content="Show age/sex" IsChecked="True" Margin="0,0,0,4" />
                                            <CheckBox x:Name="CoreReviewOnlyNewRandomCheck"
                                                      Content="Only new random cases"
                                                      IsChecked="True"
                                                      ToolTip="On by default. Core Review searches skip cases already used in previous random PowerPoints instead of backfilling with older cases."
                                                      Margin="0,0,10,0" />
                                            <CheckBox x:Name="CoreReviewOllamaCheck" Content="Ollama review" Margin="0,0,0,0" />
                                        </UniformGrid>
                                    </WrapPanel>

                                    <Border Grid.Row="2" BorderBrush="#D8E5F2" BorderThickness="1" CornerRadius="10"
                                            Padding="10" Margin="0,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="340" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                                <DockPanel LastChildFill="True" Margin="0,0,0,4">
                                                    <WrapPanel DockPanel.Dock="Right" Margin="12,0,0,0">
                                                        <Button Content="Import Sources" Style="{StaticResource PrimaryButton}"
                                                                Click="ImportPdfs_Click" Padding="10,5" />
                                                        <Button Content="Open Folder" Click="OpenBoardFolder_Click" Padding="10,5" Margin="0" />
                                                    </WrapPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="Sources &amp; Review" FontWeight="SemiBold" />
                                                        <TextBlock Text="Imported PDFs, notes, JSON, and assets stay local under library\board-review."
                                                                   Foreground="{StaticResource MutedBrush}" FontSize="12"
                                                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="Radiopaedia cases are planned separately; review cases and question types before export."
                                                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                                                           TextWrapping="Wrap" />
                                                <TextBlock x:Name="BoardStatusText" TextWrapping="Wrap" Margin="0,4,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Ollama model" FontWeight="SemiBold" />
                                                <DockPanel Margin="0,3,0,6">
                                                    <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshOllama_Click"
                                                            Padding="10,5" Margin="8,0,0,0" />
                                                    <ComboBox x:Name="CoreReviewOllamaModelCombo" IsEditable="True" />
                                                </DockPanel>
                                                <TextBlock Text="Enable Ollama review above only when you want optional image scoring."
                                                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="Library">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Case Library" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" DockPanel.Dock="Left" Margin="0,0,12,0" />
                            <TextBlock Text="Browse approved, skipped, rejected, and favorited cases from local history."
                                       Style="{StaticResource PageSubtitle}" VerticalAlignment="Center" />
                        </DockPanel>

                        <DockPanel Grid.Row="1" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Open Selected Case" Click="OpenLibraryCase_Click"
                                    Padding="10,5" Margin="8,0,0,0" />
                            <WrapPanel>
                                <TextBox x:Name="LibrarySearchBox" Width="260" Margin="0,0,8,0" />
                                <ComboBox x:Name="LibraryDecisionFilter" Width="130" Margin="0,0,8,0" />
                                <Button Content="Search" Click="RefreshLibrary_Click" Padding="10,5" />
                                <Button Content="Refresh" Click="RefreshLibrary_Click" Padding="10,5" />
                            </WrapPanel>
                        </DockPanel>

                        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="10">
                            <DataGrid x:Name="LibraryGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding CaseTitle}" Width="*" />
                                    <DataGridTextColumn Header="Decision" Binding="{Binding Decision}" Width="110" />
                                    <DataGridTextColumn Header="Seen" Binding="{Binding LastSeenAt}" Width="190" />
                                    <DataGridTextColumn Header="Images" Binding="{Binding ImageCount}" Width="75" />
                                    <DataGridTextColumn Header="Best Score" Binding="{Binding BestScore, StringFormat=0}" Width="90" />
                                    <DataGridTextColumn Header="Path" Binding="{Binding CasePath}" Width="260" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Activity">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Activity" Style="{StaticResource PageTitle}" Margin="0,0,0,12" />
                        <Expander Grid.Row="1" Header="Diagnostics and maintenance" IsExpanded="False" Margin="0,0,0,12">
                            <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DiagnosticsText" Text="Diagnostics have not been loaded yet." TextWrapping="Wrap" />
                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12,0,0,0">
                                        <Button Content="Refresh Diagnostics" Click="RefreshDiagnostics_Click" />
                                        <Button Content="Run Maintenance" Click="RunMaintenance_Click" />
                                        <Button Content="Clean Scratch" Click="CleanScratch_Click" />
                                        <Button Content="Clean Old Cache" Click="CleanOldCache_Click" />
                                        <Button Content="Open State Folder" Click="OpenStateFolder_Click" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </Expander>
                        <TextBox x:Name="ActivityLogBox" Grid.Row="2" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Consolas" FontSize="13" Background="#102132"
                                 Foreground="#D9EBF7" BorderThickness="0" Padding="14" />
                    </Grid>
                </TabItem>
            </TabControl>

        </Grid>
        <Border x:Name="ProgressPanel"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#0B1F35"
                BorderBrush="#173A63"
                BorderThickness="0,1,0,0"
                Padding="18,8,18,10"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock x:Name="ProgressPercentText"
                               DockPanel.Dock="Right"
                               Text="0%"
                               Foreground="#DBEAFE"
                               FontWeight="SemiBold"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#DBEAFE"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </DockPanel>
                <ProgressBar x:Name="Progress"
                             Grid.Row="1"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="False" />
            </Grid>
        </Border>
    </Grid>
</Window>
