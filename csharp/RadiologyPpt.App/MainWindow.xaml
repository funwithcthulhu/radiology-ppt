<Window x:Class="RadiologyPpt.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radiopaedia Case PowerPoint Builder"
        Icon="Assets/app-icon.ico"
        Height="760"
        Width="1180"
        MinHeight="520"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#0B1F35">
            <DockPanel Margin="18,24,18,18">
                <StackPanel DockPanel.Dock="Top">
                    <Border Width="58" Height="48" CornerRadius="10" Background="#173A63" HorizontalAlignment="Left">
                        <TextBlock Text="RP" Foreground="#DBEAFE" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Radiopaedia Case&#x0a;PowerPoint Builder"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,12,0,22" />
                    <Button Content="Cases" Click="CasesNav_Click" Margin="0,0,0,8" />
                    <Button Content="Library" Click="LibraryNav_Click" Margin="0,0,0,8" />
                    <Button Content="Core Review" Click="CoreBoardsNav_Click" Margin="0,0,0,8" />
                    <Button Content="Activity" Click="ActivityNav_Click" Margin="0,0,0,8" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="{Binding StatusText}" Foreground="#DBEAFE" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LastPowerPointText}" Foreground="#8FB3D8" FontSize="11"
                               TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Margin="28,24,28,16">
            <TabControl x:Name="MainTabs">
                <TabItem Header="Cases">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Cases" Style="{StaticResource PageTitle}" />
                            <TextBlock Text="Build a case conference PowerPoint from selected diagnoses, random pulls, or exact Radiopaedia URLs."
                                       Style="{StaticResource PageSubtitle}" Margin="0,4,0,0" />
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,18,12">
                                    <TextBlock Text="Case Conference" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="Settings for PowerPoints generated from the case rows below."
                                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />

                                    <TextBlock Text="Title" FontWeight="SemiBold" />
                                    <TextBox x:Name="TitleBox" Margin="0,4,0,10" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Images" FontWeight="SemiBold" />
                                            <TextBox x:Name="ImagesPerCaseBox" Text="3" Width="80" HorizontalAlignment="Left" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Theme" FontWeight="SemiBold" />
                                            <ComboBox x:Name="ThemeCombo" MaxWidth="260" HorizontalAlignment="Stretch" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,34,0,12">
                                    <TextBlock Text="Output .pptx" FontWeight="SemiBold" />
                                    <DockPanel LastChildFill="True" Margin="0,4,0,10">
                                        <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseOutput_Click" Margin="8,0,0,0" />
                                        <TextBox x:Name="OutputBox" />
                                    </DockPanel>

                                    <UniformGrid Columns="2">
                                        <CheckBox x:Name="AutoOpenCheck" Content="Open PowerPoint" IsChecked="True" Margin="0,0,10,8" />
                                        <CheckBox x:Name="ClinicalHistoryCheck" Content="Show age/sex" IsChecked="True" Margin="0,0,0,8" />
                                        <CheckBox x:Name="TeachingPointsCheck" Content="Teaching slides" Margin="0,0,10,8" />
                                        <CheckBox x:Name="OnlyNewRandomCheck"
                                                  Content="Only new random cases"
                                                  IsChecked="True"
                                                  ToolTip="On by default. Random requests search Radiopaedia first and skip cases already used in previous random PowerPoints instead of backfilling with older cases."
                                                  Margin="0,0,0,8" />
                                    </UniformGrid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,18,0">
                                    <TextBlock Text="Ollama image review" FontWeight="SemiBold" />
                                    <CheckBox x:Name="OllamaCheck" Content="Enable optional review scoring" Margin="0,4,0,8" />
                                    <DockPanel Margin="0,0,0,12">
                                        <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshOllama_Click" Margin="8,0,0,0" />
                                        <ComboBox x:Name="OllamaModelCombo" IsEditable="True" />
                                    </DockPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="Preset" FontWeight="SemiBold" />
                                    <DockPanel LastChildFill="True" Margin="0,4,0,6">
                                        <Button DockPanel.Dock="Right" Content="Apply" Click="ApplyPreset_Click" Margin="8,0,0,0" />
                                        <ComboBox x:Name="PresetCombo" DisplayMemberPath="Name" SelectionChanged="PresetCombo_SelectionChanged" />
                                    </DockPanel>
                                    <TextBlock x:Name="PresetDescriptionText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,12" />

                                    <WrapPanel>
                                        <Button x:Name="GenerateButton" Content="Generate PowerPoint" Style="{StaticResource PrimaryButton}" Click="Generate_Click" />
                                        <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click" IsEnabled="False" />
                                        <Button Content="Open Last" Click="OpenLastPowerPoint_Click" />
                                        <Button Content="Outputs" Click="OpenOutputs_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DockPanel Grid.Row="2" Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Add Row" Click="AddRow_Click" MinWidth="96" />
                                <Button Content="Remove Selected" Click="RemoveSelectedRow_Click" MinWidth="132" />
                                <Button Content="Load File" Click="LoadFile_Click" MinWidth="96" Margin="0" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Case requests" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="Add diagnoses, random pulls, or exact Radiopaedia URLs. Use the dropdowns instead of typing filter shorthand."
                                           Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="3" Style="{StaticResource Card}" MinHeight="150" MaxHeight="300" VerticalAlignment="Top">
                            <DataGrid x:Name="RequestsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridComboBoxColumn x:Name="ModeColumn" Header="Type" SelectedItemBinding="{Binding Mode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                    <DataGridTextColumn Header="Diagnosis / Random Text / URL" Binding="{Binding Query, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="Count" Binding="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                                    <DataGridComboBoxColumn x:Name="ModalityColumn" Header="Modality" SelectedItemBinding="{Binding Modality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                    <DataGridComboBoxColumn x:Name="AnatomyColumn" Header="Anatomy" SelectedItemBinding="{Binding Anatomy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                                    <DataGridComboBoxColumn x:Name="SubspecialtyColumn" Header="Area" SelectedItemBinding="{Binding Subspecialty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                                    <DataGridComboBoxColumn x:Name="AgeColumn" Header="Age" SelectedItemBinding="{Binding AgeGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                    <DataGridComboBoxColumn x:Name="TopicColumn" Header="Focus" SelectedItemBinding="{Binding TopicFocus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                    <DataGridComboBoxColumn x:Name="DifficultyColumn" Header="Difficulty" SelectedItemBinding="{Binding Difficulty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Library">
                    <Grid Margin="0,16,0,0"
                          Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Case Library" Style="{StaticResource PageTitle}" />
                            <TextBlock Text="Browse cases you approved, skipped, rejected, or favorited. This is local history only."
                                       Style="{StaticResource PageSubtitle}" Margin="0,4,0,12" />
                        </StackPanel>

                        <DockPanel Grid.Row="1" Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" Content="Open Selected Case" Click="OpenLibraryCase_Click" Margin="8,0,0,0" />
                            <WrapPanel>
                                <TextBox x:Name="LibrarySearchBox" Width="260" Margin="0,0,8,0" />
                                <ComboBox x:Name="LibraryDecisionFilter" Width="130" Margin="0,0,8,0" />
                                <Button Content="Search" Click="RefreshLibrary_Click" />
                                <Button Content="Refresh" Click="RefreshLibrary_Click" />
                            </WrapPanel>
                        </DockPanel>

                        <Border Grid.Row="2" Style="{StaticResource Card}">
                            <DataGrid x:Name="LibraryGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding CaseTitle}" Width="*" />
                                    <DataGridTextColumn Header="Decision" Binding="{Binding Decision}" Width="110" />
                                    <DataGridTextColumn Header="Seen" Binding="{Binding LastSeenAt}" Width="190" />
                                    <DataGridTextColumn Header="Images" Binding="{Binding ImageCount}" Width="75" />
                                    <DataGridTextColumn Header="Best Score" Binding="{Binding BestScore, StringFormat=0}" Width="90" />
                                    <DataGridTextColumn Header="Path" Binding="{Binding CasePath}" Width="260" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Core Review">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Core Review" Style="{StaticResource PageTitle}" />
                            <TextBlock Text="Generate CORE review lectures from here. The Cases tab is not used for this workflow."
                                       Style="{StaticResource PageSubtitle}" Margin="0,4,0,12" />
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="18,0,0,0">
                                        <Button x:Name="GenerateCoreReviewButton" Content="Generate Core Review PowerPoint"
                                                Style="{StaticResource PrimaryButton}" Click="GenerateCoreReviewPowerPoint_Click" />
                                        <Button x:Name="CoreReviewCancelButton" Content="Cancel" Click="Cancel_Click" IsEnabled="False" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Core Review PowerPoint" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Plan a CORE review lecture, choose question sources, and import study material from one place. NIS and physics count toward the total."
                                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                </DockPanel>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,18,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="128" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.ColumnSpan="2" Text="Lecture Plan" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <TextBlock Grid.Row="1" Text="Title" FontWeight="SemiBold" />
                                        <TextBox x:Name="CoreReviewTitleBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="2" Text="Total items" FontWeight="SemiBold" />
                                        <TextBox x:Name="CoreReviewCaseCountBox" Grid.Row="2" Grid.Column="1" Text="50" Width="90" HorizontalAlignment="Left" Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="3" Text="Domain" FontWeight="SemiBold" />
                                        <ComboBox x:Name="BoardDomainCombo" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="4" Text="Selection" FontWeight="SemiBold" />
                                        <ComboBox x:Name="CoreReviewCaseMixCombo" Grid.Row="4" Grid.Column="1" MaxWidth="260" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="5" Text="Modality mix" FontWeight="SemiBold" />
                                        <ComboBox x:Name="CoreReviewModalityMixCombo" Grid.Row="5" Grid.Column="1" MaxWidth="260" HorizontalAlignment="Stretch" />
                                    </Grid>

                                    <Grid Grid.Row="0" Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.ColumnSpan="2" Text="Output &amp; Questions" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <TextBlock Grid.Row="1" Text="Question source" FontWeight="SemiBold" />
                                        <ComboBox x:Name="CoreReviewQuestionSourceCombo" Grid.Row="1" Grid.Column="1" MaxWidth="300" HorizontalAlignment="Stretch" Margin="0,0,0,8" SelectionChanged="CoreReviewQuestionSourceCombo_SelectionChanged" />
                                        <TextBlock x:Name="CoreReviewQuestionBankLabel" Grid.Row="2" Text="Question bank" FontWeight="SemiBold" />
                                        <DockPanel x:Name="CoreReviewQuestionBankPanel" Grid.Row="2" Grid.Column="1" LastChildFill="True" Margin="0,0,0,8">
                                            <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseCoreReviewQuestionBank_Click" Margin="8,0,0,0" />
                                            <TextBox x:Name="CoreReviewQuestionBankBox" />
                                        </DockPanel>
                                        <TextBlock Grid.Row="3" Text="Theme" FontWeight="SemiBold" />
                                        <ComboBox x:Name="CoreReviewThemeCombo" Grid.Row="3" Grid.Column="1" MaxWidth="260" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="4" Text="Output .pptx" FontWeight="SemiBold" />
                                        <DockPanel Grid.Row="4" Grid.Column="1" LastChildFill="True" Margin="0,0,0,8">
                                            <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseCoreReviewOutput_Click" Margin="8,0,0,0" />
                                            <TextBox x:Name="CoreReviewOutputBox" />
                                        </DockPanel>
                                        <UniformGrid Grid.Row="5" Grid.Column="1" Columns="2">
                                            <CheckBox x:Name="CoreReviewAutoOpenCheck" Content="Open PowerPoint" IsChecked="True" Margin="0,0,10,6" />
                                            <CheckBox x:Name="CoreReviewClinicalHistoryCheck" Content="Show age/sex" IsChecked="True" Margin="0,0,0,6" />
                                            <CheckBox x:Name="CoreReviewOnlyNewRandomCheck"
                                                      Content="Only new random cases"
                                                      IsChecked="True"
                                                      ToolTip="On by default. Core Review searches skip cases already used in previous random PowerPoints instead of backfilling with older cases."
                                                      Margin="0,0,10,0" />
                                            <CheckBox x:Name="CoreReviewOllamaCheck" Content="Ollama review" Margin="0,0,0,0" />
                                        </UniformGrid>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,0">
                                        <TextBlock Text="Sources &amp; Review" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <TextBlock Text="Imported PDFs, notes, JSON files, and extracted assets stay local under library\board-review."
                                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                        <WrapPanel Margin="0,0,0,12">
                                            <Button Content="Import Sources" Style="{StaticResource PrimaryButton}" Click="ImportPdfs_Click" />
                                            <Button Content="Open Folder" Click="OpenBoardFolder_Click" />
                                        </WrapPanel>
                                        <TextBlock x:Name="BoardStatusText" TextWrapping="Wrap" Margin="0,0,0,12" />
                                        <TextBlock Text="Ollama model" FontWeight="SemiBold" />
                                        <DockPanel Margin="0,4,0,10">
                                            <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshOllama_Click" Margin="8,0,0,0" />
                                            <ComboBox x:Name="CoreReviewOllamaModelCombo" IsEditable="True" />
                                        </DockPanel>
                                        <TextBlock Text="Cases are searched from Radiopaedia using separate Core Review planning logic, then reviewed before export."
                                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Activity">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Activity" Style="{StaticResource PageTitle}" Margin="0,0,0,12" />
                        <Expander Grid.Row="1" Header="Diagnostics and maintenance" IsExpanded="False" Margin="0,0,0,12">
                            <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DiagnosticsText" Text="Diagnostics have not been loaded yet." TextWrapping="Wrap" />
                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12,0,0,0">
                                        <Button Content="Refresh Diagnostics" Click="RefreshDiagnostics_Click" />
                                        <Button Content="Run Maintenance" Click="RunMaintenance_Click" />
                                        <Button Content="Clean Scratch" Click="CleanScratch_Click" />
                                        <Button Content="Clean Old Cache" Click="CleanOldCache_Click" />
                                        <Button Content="Open State Folder" Click="OpenStateFolder_Click" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </Expander>
                        <TextBox x:Name="ActivityLogBox" Grid.Row="2" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Consolas" FontSize="13" Background="#102132"
                                 Foreground="#D9EBF7" BorderThickness="0" Padding="14" />
                    </Grid>
                </TabItem>
            </TabControl>

        </Grid>
        <Border x:Name="ProgressPanel"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#0B1F35"
                BorderBrush="#173A63"
                BorderThickness="0,1,0,0"
                Padding="18,8,18,10"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock x:Name="ProgressPercentText"
                               DockPanel.Dock="Right"
                               Text="0%"
                               Foreground="#DBEAFE"
                               FontWeight="SemiBold"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#DBEAFE"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </DockPanel>
                <ProgressBar x:Name="Progress"
                             Grid.Row="1"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="False" />
            </Grid>
        </Border>
    </Grid>
</Window>
