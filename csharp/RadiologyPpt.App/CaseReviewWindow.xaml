<Window x:Class="RadiologyPpt.App.CaseReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Review Prepared Cases"
        Width="1220"
        Height="760"
        MinWidth="940"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_SourceInitialized">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="ProgressTitle" Text="Case Review" Style="{StaticResource PageTitle}" />
                <TextBlock x:Name="CaseTitle" FontSize="22" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                <TextBlock x:Name="CaseIntro" Style="{StaticResource PageSubtitle}" Margin="0,6,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="Cancel Review" Click="CancelReview_Click" VerticalAlignment="Top" />
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="Images">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Images" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <TextBox x:Name="ImagesBox" Grid.Column="1" Width="58" HorizontalAlignment="Left" Text="3" />
                            <TextBlock Grid.Column="2" Text="Crop" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <ComboBox x:Name="CropCombo" Grid.Column="3" />
                            <TextBlock Grid.Column="4" Text="Markup" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <ComboBox x:Name="MarkupCombo" Grid.Column="5" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ImageItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="340" MinHeight="330" Margin="0,0,16,16"
                                                Background="#F7FAFC" BorderBrush="#D7E3EC" BorderThickness="1"
                                                CornerRadius="10" Padding="12">
                                            <DockPanel LastChildFill="True">
                                                <CheckBox DockPanel.Dock="Top" Content="Keep this image" IsChecked="{Binding Keep, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                <TextBlock DockPanel.Dock="Bottom" Text="{Binding Caption}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" />
                                                <Border Background="Black" CornerRadius="6" ClipToBounds="True">
                                                    <Image Source="{Binding LocalPath}" Stretch="Uniform" MaxHeight="245" />
                                                </Border>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Details">
                <TextBox x:Name="DetailsBox" Margin="0,12,0,0" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="12" />
            </TabItem>

            <TabItem Header="Candidates">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Choose exact candidate images from the same Radiopaedia case, then fetch those frames as the selected images."
                                   Style="{StaticResource PageSubtitle}" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="Use Selected Candidates" Style="{StaticResource PrimaryButton}" Click="UseSelectedCandidates_Click" />
                    </DockPanel>
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="CandidateItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="320" MinHeight="240" Margin="0,0,14,14"
                                                Background="#F7FAFC" BorderBrush="#D7E3EC" BorderThickness="1"
                                                CornerRadius="10" Padding="12">
                                            <DockPanel LastChildFill="True">
                                                <CheckBox DockPanel.Dock="Top" Content="Use this candidate" IsChecked="{Binding Use, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                                    <TextBlock Text="{Binding Caption}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                                                    <TextBlock Text="{Binding ScoreText}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                                </StackPanel>
                                                <Border Background="Black" CornerRadius="6" ClipToBounds="True">
                                                    <Image Source="{Binding PreviewPath}" Stretch="Uniform" MaxHeight="170" />
                                                </Border>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="0,16,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button x:Name="KeepNextButton" Content="Keep Case &amp; Next" Style="{StaticResource PrimaryButton}" Click="KeepNext_Click" />
                <Button Content="Skip Case" Click="Skip_Click" />
                <Button x:Name="RerollButton" Content="Reroll Case" Click="Reroll_Click" />
                <Button x:Name="RepickButton" Content="Re-pick Images" Click="Repick_Click" />
                <Button x:Name="ReplaceUncheckedButton" Content="Replace Unchecked" Click="ReplaceUnchecked_Click" />
                <Button Content="Remove Unchecked" Click="RemoveUnchecked_Click" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <ProgressBar x:Name="BusyProgress" Width="160" Height="8" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,10,0" />
                <Button x:Name="CancelActionButton" Content="Cancel Action" Click="CancelAction_Click" IsEnabled="False" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
