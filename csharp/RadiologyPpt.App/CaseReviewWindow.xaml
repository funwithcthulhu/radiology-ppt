<Window x:Class="RadiologyPpt.App.CaseReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Review Prepared Cases"
        Icon="Assets/app-icon.ico"
        Width="1220"
        Height="760"
        MinWidth="940"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_SourceInitialized"
        KeyDown="Window_KeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <DockPanel LastChildFill="True">
                    <TextBlock x:Name="ProgressTitle" Text="Case Review" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}" DockPanel.Dock="Left" Margin="0,0,18,0" />
                    <TextBlock x:Name="CaseTitle" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                </DockPanel>
                <TextBlock x:Name="CaseIntro" Style="{StaticResource PageSubtitle}" Margin="0,3,0,0" />
                <DockPanel Margin="0,4,0,0">
                    <TextBlock x:Name="QualityBadge" DockPanel.Dock="Left" Foreground="#0F766E"
                               FontWeight="SemiBold" Margin="0,0,18,0" TextWrapping="Wrap" />
                    <TextBlock Text="Shortcuts: K keep, F favorite, S skip, R reroll, I re-pick, Delete remove unchecked, Esc cancel."
                               Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" />
                </DockPanel>
                <DockPanel x:Name="CoreReviewExercisePanel" Margin="0,8,0,0" LastChildFill="True" Visibility="Collapsed">
                    <TextBlock Text="Core Review slide type" DockPanel.Dock="Left" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,10,0" />
                    <ComboBox x:Name="CoreReviewExerciseTypeCombo" DockPanel.Dock="Left" Width="240"
                              DisplayMemberPath="Label" SelectedValuePath="Value" />
                    <TextBlock Text="Choose Auto for the normal mix, or override this reviewed case before keeping it."
                               Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </DockPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="Cancel Review" Click="CancelReview_Click"
                    VerticalAlignment="Top" Padding="12,7" />
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="Images">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <TextBlock Text="Images" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                            <TextBox x:Name="ImagesBox" Width="52" Text="3" />
                        </StackPanel>
                        <TextBlock Text="Selected Images" VerticalAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" />
                    </DockPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseWheel="SlowImageScroll_PreviewMouseWheel">
                            <ItemsControl x:Name="ImageItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="520" MinHeight="410" Margin="0,0,16,16"
                                                Background="#F7FAFC" BorderBrush="#D7E3EC" BorderThickness="1"
                                                CornerRadius="10" Padding="10">
                                            <DockPanel LastChildFill="True">
                                                <CheckBox DockPanel.Dock="Top" Content="Keep this image" IsChecked="{Binding Keep, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                                    <TextBlock Text="{Binding Caption}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                                                    <TextBlock Text="{Binding SelectionExplanation}" TextWrapping="Wrap" Foreground="#334155" FontSize="11" Margin="0,4,0,0" />
                                                    <TextBlock Text="{Binding OllamaText}" TextWrapping="Wrap" Foreground="#0F766E" FontSize="11" Margin="0,4,0,0" />
                                                </StackPanel>
                                                <Border Background="Black" CornerRadius="6" ClipToBounds="True">
                                                    <Image Source="{Binding ImageSource}" Stretch="Uniform" MaxHeight="330" />
                                                </Border>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Details">
                <TextBox x:Name="DetailsBox" Margin="0,12,0,0" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="12" />
            </TabItem>

            <TabItem Header="Candidates">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Choose exact candidate images from the same Radiopaedia case, then fetch those frames as the selected images."
                                   Style="{StaticResource PageSubtitle}" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="Use Selected Candidates" Style="{StaticResource PrimaryButton}" Click="UseSelectedCandidates_Click" />
                    </DockPanel>
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseWheel="SlowImageScroll_PreviewMouseWheel">
                            <ItemsControl x:Name="CandidateItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="320" MinHeight="240" Margin="0,0,14,14"
                                                Background="#F7FAFC" BorderBrush="#D7E3EC" BorderThickness="1"
                                                CornerRadius="10" Padding="12">
                                            <DockPanel LastChildFill="True">
                                                <CheckBox DockPanel.Dock="Top" Content="Use this candidate" IsChecked="{Binding Use, Mode=TwoWay}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                                    <TextBlock Text="{Binding Caption}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                                                    <TextBlock Text="{Binding ScoreText}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                                </StackPanel>
                                                <Border Background="Black" CornerRadius="6" ClipToBounds="True">
                                                    <Image Source="{Binding PreviewSource}" Stretch="Uniform" MaxHeight="170" />
                                                </Border>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button x:Name="KeepNextButton" Content="Keep Case &amp; Next" Style="{StaticResource PrimaryButton}" Click="KeepNext_Click" />
                <Button x:Name="FavoriteNextButton" Content="Favorite &amp; Next" Click="FavoriteNext_Click" />
                <Button Content="Skip Case" Click="Skip_Click" />
                <Button x:Name="RerollButton" Content="Reroll Case" Click="Reroll_Click" />
                <Button x:Name="RepickButton" Content="Re-pick Images" Click="Repick_Click" />
                <Button x:Name="OllamaScoreButton" Content="Ollama Score Case" Click="OllamaScore_Click" />
                <Button x:Name="ReplaceUncheckedButton" Content="Replace Unchecked" Click="ReplaceUnchecked_Click" />
                <Button Content="Remove Unchecked" Click="RemoveUnchecked_Click" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <ProgressBar x:Name="BusyProgress" Width="160" Height="8" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,10,0" />
                <Button x:Name="CancelActionButton" Content="Cancel Action" Click="CancelAction_Click" IsEnabled="False" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
